generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TEAM
  CLIENT
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  profile             Profile?
  invites             Invite[]
  passwordResetTokens PasswordResetToken[]
  timeEntries         TimeEntry[]
  notes               Note[]
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName String
  phone     String?
  lastName  String
}

model Invoice {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  amount Float
  status InvoiceStatus @default(DRAFT)

  issuedAt DateTime?
  paidAt   DateTime?

  createdAt     DateTime @default(now())
  depositQuotes Quote[]
}

model QuoteBundle {
  id String @id @default(uuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id])

  name String

  showToCustomer Boolean @default(true)

  createdAt DateTime @default(now())

  lines        QuoteLine[]
  bomId        String?
  bom          BillOfMaterials? @relation(fields: [bomId], references: [id])
  salesOrder   SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  salesOrderId String?
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

model Invite {
  id        String @id @default(uuid())
  token     String @unique
  email     String
  trainerId String
  trainer   User   @relation(fields: [trainerId], references: [id])

  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Customer {
  id          String  @id @default(uuid())
  name        String
  email       String?
  phone       String?
  billingTerm String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes        Quote[]
  projects      Project[]
  itemPrices    CustomerItemPrice[]
  subscriptions Subscription[]
  salesOrders   SalesOrder[]
}

enum BillingTerms {
  NET30
  PROGRESS
  PREPAID
}

model Item {
  id           String  @id @default(uuid())
  itemNumber   String  @unique
  manufacturer String?

  cost  Float?
  price Float?

  lastSoldPrice Float?

  active   Boolean @default(true)
  approved Boolean @default(false)

  eolDate DateTime?

  category String?
  type     ItemType
  unit     String?

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  customerPrices     CustomerItemPrice[]
  description        String?
  priceHistory       ItemPriceHistory[]
  shipments          Shipment[]
  quoteLines         QuoteLine[]
  subscriptions      Subscription[]
  purchaseOrderLines PurchaseOrderLine[]
  bomlines           BOMLine[]
  salesOrderLines    SalesOrderLine[]
  scopes             ProjectScope[]
  shipmentLines      ShipmentLine[]
}

enum ItemType {
  HARDWARE
  SOFTWARE
  SUBSCRIPTION
  SERVICE
}

model Quote {
  id             String          @id @default(uuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id])
  status         QuoteStatus     @default(DRAFT)
  total          Float?
  createdAt      DateTime        @default(now())
  lines          QuoteLine[]
  quoteBundles   QuoteBundle[]
  boms           QuoteBOM[]
  salesOrder     SalesOrder?
  purchaseOrders PurchaseOrder[]

  depositPct       Float? // e.g. 50.0
  depositAmount    Float? // fixed override — if set, takes precedence over pct
  depositPaid      Boolean   @default(false)
  depositPaidAt    DateTime?
  depositInvoiceId String?
  depositInvoice   Invoice?  @relation(fields: [depositInvoiceId], references: [id])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model QuoteLine {
  id String @id @default(uuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id])

  bundleId String?
  bundle   QuoteBundle? @relation(fields: [bundleId], references: [id])

  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  description String
  quantity    Int
  price       Float

  cost Float?
}

model CustomerItemPrice {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  price     Float
  createdAt DateTime @default(now())

  @@unique([customerId, itemId])
}

model Project {
  id String @id @default(uuid())

  name String

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  billingTerms BillingTerms? // ← ADD THIS

  totalBudget Float?
  invoiced    Float?

  createdAt DateTime @default(now())

  milestones     ProjectMilestone[]
  shipments      Shipment[]
  invoices       Invoice[]
  timeEntries    TimeEntry[]
  changeOrders   ChangeOrder[]
  purchaseOrders PurchaseOrder[]
  quotes         Quote[]
  boms           BillOfMaterials[]
  salesOrders    SalesOrder[]
  scopes         ProjectScope[]
}

model Subscription {
  id String @id @default(uuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  startDate DateTime
  endDate   DateTime

  status SubscriptionStatus

  notes String?

  createdAt DateTime @default(now())
}

model ProjectScope {
  id             String      @id @default(uuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id])
  itemId         String?
  item           Item?       @relation(fields: [itemId], references: [id])
  name           String
  estimatedHours Float       @default(0)
  timeEntries    TimeEntry[]
  createdAt      DateTime    @default(now())
}

model TimeEntry {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  scopeId   String?
  scope     ProjectScope? @relation(fields: [scopeId], references: [id])
  hours     Float
  notes     String?
  date      DateTime      @default(now())
  createdAt DateTime      @default(now())
}

model ItemPriceHistory {
  id String @id @default(uuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  cost  Float?
  price Float?

  changedBy String?
  createdAt DateTime @default(now())
}

model ChangeOrder {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  description String

  amount Float

  createdAt DateTime @default(now())
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_RENEWAL
  EXPIRED
}

model ProjectMilestone {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  name      String
  dueDate   DateTime?
  completed Boolean   @default(false)
}

model BillOfMaterials {
  id        String   @id @default(uuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines  BOMLine[]
  quotes QuoteBOM[]

  quoteBundles QuoteBundle[]
}

model QuoteBOM {
  quoteId String
  quote   Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  bomId   String
  bom     BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@id([quoteId, bomId])
}

model BOMLine {
  id        String          @id @default(uuid())
  bomId     String
  bom       BillOfMaterials @relation(fields: [bomId], references: [id])
  itemId    String
  item      Item            @relation(fields: [itemId], references: [id])
  quantity  Int
  notes     String?
  section   String?
  costEach  Float?
  sellEach  Float?
  sortOrder Int?
}

enum NoteDocumentType {
  QUOTE
  BILL_OF_MATERIALS
  CHANGE_ORDER
  SALES_ORDER
}

model Note {
  id           String           @id @default(uuid())
  documentType NoteDocumentType
  documentId   String
  content      String
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  createdAt    DateTime         @default(now())

  @@index([documentType, documentId])
}

enum SalesOrderStatus {
  OPEN
  FULFILLED
  CLOSED
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  vendor        String
  notes         String?
  projectId     String?
  project       Project?            @relation(fields: [projectId], references: [id])
  quoteId       String?
  quote         Quote?              @relation(fields: [quoteId], references: [id])
  salesOrderId  String?
  salesOrder    SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  status        POStatus            @default(DRAFT)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  lines         PurchaseOrderLine[]
  shipments     Shipment[]
  shipmentLines ShipmentLine[]
}

model PurchaseOrderLine {
  id               String          @id @default(uuid())
  poId             String
  purchaseOrder    PurchaseOrder   @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId           String
  item             Item            @relation(fields: [itemId], references: [id])
  salesOrderLineId String?
  salesOrderLine   SalesOrderLine? @relation(fields: [salesOrderLineId], references: [id])
  quantity         Int
  receivedQuantity Int             @default(0)
  cost             Float
  shipmentLines    ShipmentLine[]
}

model SalesOrderLine {
  id                 String              @id @default(cuid())
  salesOrderId       String
  salesOrder         SalesOrder          @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  description        String
  quantity           Int
  price              Decimal             @db.Decimal(10, 2)
  cost               Decimal?            @db.Decimal(10, 2)
  itemId             String?
  item               Item?               @relation(fields: [itemId], references: [id])
  purchaseOrderLines PurchaseOrderLine[]
}

model SalesOrder {
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  status         SalesOrderStatus @default(OPEN)
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id])
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id])
  quoteId        String?          @unique
  quote          Quote?           @relation(fields: [quoteId], references: [id])
  lines          SalesOrderLine[]
  quoteBundles   QuoteBundle[]
  purchaseOrders PurchaseOrder[]
  shipments      Shipment[]
}

model Shipment {
  id               String         @id @default(uuid())
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id])
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  salesOrderId     String?
  salesOrder       SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  itemId           String?
  item             Item?          @relation(fields: [itemId], references: [id])
  quantity         Int
  receivedQuantity Int            @default(0)
  carrier          String?
  tracking         String?
  shippedBy        String?
  notes            String?
  receivedAt       DateTime?
  createdAt        DateTime       @default(now())
  lines            ShipmentLine[]
}

model ShipmentLine {
  id              String             @id @default(uuid())
  shipmentId      String
  shipment        Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  itemId          String?
  item            Item?              @relation(fields: [itemId], references: [id])
  poLineId        String?
  poLine          PurchaseOrderLine? @relation(fields: [poLineId], references: [id])
  quantity        Int
  createdAt       DateTime           @default(now())
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?
}

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
}
