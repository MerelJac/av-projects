generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TEAM
  CLIENT
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  profile             Profile?
  invites             Invite[]
  passwordResetTokens PasswordResetToken[]
  timeEntries         TimeEntry[]
  notes               Note[]
  auditLogs           AuditLog[]
  defaultBuyerVendors Vendor[]             @relation("VendorDefaultBuyer")
  purchaseOrdersBuyer PurchaseOrder[]      @relation("POBuyer")
}

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName String
  phone     String?
  lastName  String
}

model Invoice {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  quoteId String?
  quote   Quote?  @relation("QuoteInvoices", fields: [quoteId], references: [id])

  invoiceNumber String?
  chargeType    InvoiceChargeType @default(LINE_ITEMS)
  chargePercent Float? // e.g. 50.0 — used when chargeType = PERCENTAGE

  amount Float?
  status InvoiceStatus @default(DRAFT)

  // Contact info snapshot — copied from customer at creation, editable per invoice
  customerName  String?
  customerEmail String?
  customerPhone String?
  billToAddress String?
  shipToAddress String?
  billingTerms  BillingTerms?

  notes    String?
  issuedAt DateTime?
  dueDate  DateTime?
  paidAt   DateTime?

  createdAt DateTime @default(now())

  lines              InvoiceLine[]
  depositQuotes      Quote[]             @relation("DepositInvoice")
  inventoryMovements InventoryMovement[]
}

model InvoiceLine {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Float
  price       Float

  // Source reference (optional)
  quoteLineId   String?
  quoteBundleId String?
  isBundleTotal Boolean       @default(false) // true = rolled-up hidden-bundle line
  scopeId       String?
  scope         ProjectScope? @relation(fields: [scopeId], references: [id])

  // Inventory tracking
  itemId             String?
  item               Item?               @relation(fields: [itemId], references: [id])
  inventoryMovements InventoryMovement[]
}

model QuoteBundle {
  id String @id @default(uuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id])

  name String

  showToCustomer Boolean @default(true)

  createdAt DateTime @default(now())

  lines        QuoteLine[]
  bomId        String?
  bom          BillOfMaterials? @relation(fields: [bomId], references: [id])
  salesOrder   SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  salesOrderId String?
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  REJECTED
  REVISED
  VOID
}

enum InvoiceChargeType {
  LINE_ITEMS
  PERCENTAGE
}

model Invite {
  id        String @id @default(uuid())
  token     String @unique
  email     String
  trainerId String
  trainer   User   @relation(fields: [trainerId], references: [id])

  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Customer {
  id          String  @id @default(uuid())
  bcId        String? @unique // Business Central customer ID
  name        String
  email       String?
  phone       String?
  billingTerm String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bcSyncedAt DateTime?

  quotes        Quote[]
  projects      Project[]
  itemPrices    CustomerItemPrice[]
  subscriptions Subscription[]
  salesOrders   SalesOrder[]
}

enum BillingTerms {
  NET30
  PROGRESS
  PREPAID
}

model Item {
  id           String  @id @default(uuid())
  bcId         String? @unique // Business Central item ID
  itemNumber   String  @unique
  manufacturer String?

  cost  Float?
  price Float?

  lastSoldPrice Float?

  active   Boolean @default(true)
  approved Boolean @default(false)

  eolDate DateTime?

  category String?
  type     ItemType
  unit     String?

  preferredVendorId String?
  preferredVendor   Vendor? @relation("ItemPreferredVendor", fields: [preferredVendorId], references: [id])

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bcSyncedAt         DateTime?
  customerPrices     CustomerItemPrice[]
  description        String?
  priceHistory       ItemPriceHistory[]
  shipments          Shipment[]
  quoteLines         QuoteLine[]
  subscriptions      Subscription[]
  purchaseOrderLines PurchaseOrderLine[]
  bomlines           BOMLine[]
  salesOrderLines    SalesOrderLine[]
  scopes             ProjectScope[]
  shipmentLines      ShipmentLine[]
  vendorPrices       VendorItemPrice[]
  inventoryMovements InventoryMovement[]
  invoiceLines       InvoiceLine[]
}

enum ItemType {
  HARDWARE
  SOFTWARE
  SUBSCRIPTION
  INTERNAL_SERVICE
  EXTERNAL_SERVICE
}

model Quote {
  id             String          @id @default(uuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id])
  status         QuoteStatus     @default(DRAFT)
  total          Float?
  createdAt      DateTime        @default(now())
  lines          QuoteLine[]
  quoteBundles   QuoteBundle[]
  boms           QuoteBOM[]
  salesOrder     SalesOrder?
  purchaseOrders PurchaseOrder[]

  depositPct       Float? // e.g. 50.0
  depositAmount    Float? // fixed override — if set, takes precedence over pct
  depositPaid      Boolean   @default(false)
  depositPaidAt    DateTime?
  depositInvoiceId String?
  depositInvoice   Invoice?  @relation("DepositInvoice", fields: [depositInvoiceId], references: [id])
  invoices         Invoice[] @relation("QuoteInvoices")

  isDirect               Boolean @default(false)
  isChangeOrder          Boolean @default(false)
  scopeOfWork            String?
  termsAndConditions     String?
  clientResponsibilities String?
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model QuoteLine {
  id String @id @default(uuid())

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id])

  bundleId String?
  bundle   QuoteBundle? @relation(fields: [bundleId], references: [id])

  itemId String?
  item   Item?   @relation(fields: [itemId], references: [id])

  description String
  quantity    Int
  price       Float

  cost Float?
}

model CustomerItemPrice {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  price     Float
  createdAt DateTime @default(now())

  @@unique([customerId, itemId])
}

model Salesperson {
  id       String    @id @default(uuid())
  name     String
  projects Project[]
}

model Project {
  id String @id @default(uuid())

  name          String
  salespersonId String?
  salesperson   Salesperson? @relation(fields: [salespersonId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  billingTerms BillingTerms?

  totalBudget Float?
  invoiced    Float?

  createdAt DateTime @default(now())

  milestones     ProjectMilestone[]
  shipments      Shipment[]
  invoices       Invoice[]
  timeEntries    TimeEntry[]
  changeOrders   ChangeOrder[]
  purchaseOrders PurchaseOrder[]
  quotes         Quote[]
  boms           BillOfMaterials[]
  salesOrders    SalesOrder[]
  scopes         ProjectScope[]
  costs          ProjectCost[]
}

// ─── Project Costs ─────────────────────────────────────────────────────────────

enum ProjectCostType {
  MATERIAL
  LABOR
  FREIGHT
  RETURN
  TAX
  OTHER
}

/// Tracks actual costs incurred per project (from BOM lines, POs, etc.)
model ProjectCost {
  id         String           @id @default(uuid())
  projectId  String
  project    Project          @relation(fields: [projectId], references: [id])
  bomId      String?
  bom        BillOfMaterials? @relation(fields: [bomId], references: [id])
  bomLineId  String?
  bomLine    BOMLine?         @relation(fields: [bomLineId], references: [id])
  itemId     String?
  costType   ProjectCostType
  unitCost   Float?
  quantity   Float?
  amount     Float
  poLink     String? // PO number or ID reference
  notes      String?
  createdAt  DateTime         @default(now())
  shipmentId String?
  shipment   Shipment?        @relation(fields: [shipmentId], references: [id])

  poReturnId String?
  poReturn   PurchaseOrderReturn? @relation(fields: [poReturnId], references: [id])

  @@index([projectId])
  @@index([bomId])
}

model Subscription {
  id String @id @default(uuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  startDate DateTime
  endDate   DateTime

  status SubscriptionStatus

  notes String?

  createdAt DateTime @default(now())
}

model ProjectScope {
  id             String        @id @default(uuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])
  itemId         String?
  item           Item?         @relation(fields: [itemId], references: [id])
  name           String
  estimatedHours Float         @default(0)
  ratePerHour    Float?
  costPerHour    Float?
  timeEntries    TimeEntry[]
  invoiceLines   InvoiceLine[]
  createdAt      DateTime      @default(now())
}

model TimeEntry {
  id        String        @id @default(uuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  scopeId   String?
  scope     ProjectScope? @relation(fields: [scopeId], references: [id])
  hours     Float
  notes     String?
  date      DateTime      @default(now())
  createdAt DateTime      @default(now())
}

model ItemPriceHistory {
  id String @id @default(uuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  cost  Float?
  price Float?

  changedBy String?
  createdAt DateTime @default(now())
}

model ChangeOrder {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  description String

  amount Float

  createdAt DateTime @default(now())
}

enum SubscriptionStatus {
  ACTIVE
  PENDING_RENEWAL
  EXPIRED
}

model ProjectMilestone {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  name      String
  dueDate   DateTime?
  completed Boolean   @default(false)
}

model BillOfMaterials {
  id        String   @id @default(uuid())
  name      String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines  BOMLine[]
  quotes QuoteBOM[]

  quoteBundles QuoteBundle[]
  costs        ProjectCost[]
}

model QuoteBOM {
  quoteId String
  quote   Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  bomId   String
  bom     BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)

  @@id([quoteId, bomId])
}

model BOMLine {
  id        String          @id @default(uuid())
  bomId     String
  bom       BillOfMaterials @relation(fields: [bomId], references: [id])
  itemId    String
  item      Item            @relation(fields: [itemId], references: [id])
  quantity  Int
  notes     String?
  section   String?
  costEach  Float?
  sellEach  Float?
  sortOrder Int?

  poLink     String? // Optional PO number/ID entered manually
  actualCost Float? // Actual cost paid for this line

  inventoryMovements InventoryMovement[]
  projectCosts       ProjectCost[]
}

enum NoteDocumentType {
  QUOTE
  BILL_OF_MATERIALS
  CHANGE_ORDER
  SALES_ORDER
  PURCHASE_ORDER
  INVOICE
}

model Note {
  id           String           @id @default(uuid())
  documentType NoteDocumentType
  documentId   String
  content      String
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  createdAt    DateTime         @default(now())

  @@index([documentType, documentId])
}

enum SalesOrderStatus {
  OPEN
  FULFILLED
  CLOSED
}

model PurchaseOrder {
  id             String                @id @default(uuid())
  poNumber       String?
  revision       Int                   @default(1)
  sentAt         DateTime?
  vendorId       String?
  vendor         Vendor?               @relation(fields: [vendorId], references: [id])
  notes          String?
  projectId      String?
  project        Project?              @relation(fields: [projectId], references: [id])
  quoteId        String?
  quote          Quote?                @relation(fields: [quoteId], references: [id])
  salesOrderId   String?
  salesOrder     SalesOrder?           @relation(fields: [salesOrderId], references: [id])
  status         POStatus              @default(DRAFT)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  // Snapshot fields — copied from vendor defaults at creation, editable per PO
  shipToAddress  String?
  billToAddress  String?
  shippingMethod String?
  billingTerms   BillingTerms?
  creditLimit    Decimal?              @db.Decimal(10, 2)
  buyerId        String?
  buyer          User?                 @relation("POBuyer", fields: [buyerId], references: [id])
  lines          PurchaseOrderLine[]
  shipments      Shipment[]
  shipmentLines  ShipmentLine[]
  returns        PurchaseOrderReturn[]
}

model PurchaseOrderLine {
  id               String                    @id @default(uuid())
  poId             String
  purchaseOrder    PurchaseOrder             @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId           String
  item             Item                      @relation(fields: [itemId], references: [id])
  salesOrderLineId String?
  salesOrderLine   SalesOrderLine?           @relation(fields: [salesOrderLineId], references: [id])
  quantity         Int
  receivedQuantity Int                       @default(0)
  cost             Float
  costOverridden   Boolean                   @default(false)
  shipmentLines    ShipmentLine[]
  returnLines      PurchaseOrderReturnLine[]
}

model PurchaseOrderReturn {
  id           String                    @id @default(uuid())
  returnNumber String?
  poId         String
  po           PurchaseOrder             @relation(fields: [poId], references: [id], onDelete: Cascade)
  status       ReturnStatus              @default(PENDING)
  disposition  ReturnDisposition         @default(RETURN_TO_VENDOR)
  reason       String?
  rmaNumber    String?
  notes        String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  lines        PurchaseOrderReturnLine[]
  projectCosts ProjectCost[]
}

model PurchaseOrderReturnLine {
  id            String              @id @default(uuid())
  returnId      String
  poReturn      PurchaseOrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  poLineId      String
  poLine        PurchaseOrderLine   @relation(fields: [poLineId], references: [id])
  quantity      Int
  creditPerUnit Float?
}

model SalesOrderLine {
  id                 String              @id @default(cuid())
  salesOrderId       String
  salesOrder         SalesOrder          @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  description        String
  quantity           Int
  price              Decimal             @db.Decimal(10, 2)
  cost               Decimal?            @db.Decimal(10, 2)
  itemId             String?
  item               Item?               @relation(fields: [itemId], references: [id])
  purchaseOrderLines PurchaseOrderLine[]
}

model Vendor {
  id             String        @id @default(uuid())
  bcId           String?       @unique // Business Central vendor ID
  name           String
  email          String?
  phone          String?
  notes          String?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  bcSyncedAt     DateTime?
  // Default fields — copied to PO at creation, editable per PO
  shipToAddress  String?
  billToAddress  String?
  shippingMethod String?
  billingTerms   BillingTerms?
  creditLimit    Decimal?      @db.Decimal(10, 2)
  defaultBuyerId String?
  defaultBuyer   User?         @relation("VendorDefaultBuyer", fields: [defaultBuyerId], references: [id])

  purchaseOrders    PurchaseOrder[]
  itemPrices        VendorItemPrice[]
  preferredForItems Item[]            @relation("ItemPreferredVendor")
}

model VendorItemPrice {
  id       String @id @default(uuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])

  cost         Float
  leadTimeDays Int?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, itemId])
}

model ItemDropdownOption {
  id        String   @id @default(uuid())
  field     String // "category" | "unit"
  value     String
  createdAt DateTime @default(now())

  @@unique([field, value])
}

model SalesOrder {
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  status         SalesOrderStatus @default(OPEN)
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id])
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id])
  quoteId        String?          @unique
  quote          Quote?           @relation(fields: [quoteId], references: [id])
  lines          SalesOrderLine[]
  quoteBundles   QuoteBundle[]
  purchaseOrders PurchaseOrder[]
  shipments      Shipment[]
}

model Shipment {
  id                 String              @id @default(uuid())
  projectId          String
  project            Project             @relation(fields: [projectId], references: [id])
  purchaseOrderId    String?
  purchaseOrder      PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id])
  salesOrderId       String?
  salesOrder         SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  itemId             String?
  item               Item?               @relation(fields: [itemId], references: [id])
  quantity           Int
  receivedQuantity   Int                 @default(0)
  carrier            String?
  tracking           String?
  shippedBy          String?
  notes              String?
  cost               Decimal?            @db.Decimal(10, 2)
  receivedAt         DateTime?
  createdAt          DateTime            @default(now())
  lines              ShipmentLine[]
  inventoryMovements InventoryMovement[]
  projectCosts       ProjectCost[]
}

model ShipmentLine {
  id              String             @id @default(uuid())
  shipmentId      String
  shipment        Shipment           @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  itemId          String?
  item            Item?              @relation(fields: [itemId], references: [id])
  poLineId        String?
  poLine          PurchaseOrderLine? @relation(fields: [poLineId], references: [id])
  quantity        Int
  createdAt       DateTime           @default(now())
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?
}

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  PARTIALLY_RETURNED
  RETURNED
  CANCELLED
}

enum ReturnStatus {
  PENDING
  SENT
  CREDITED
  CANCELLED
}

enum ReturnDisposition {
  RETURN_TO_VENDOR // item leaves — inventory decremented
  KEEP_IN_INVENTORY // item stays — inventory incremented back
}

model AuditLog {
  id           String   @id @default(cuid())
  documentType String // QUOTE | PURCHASE_ORDER | INVOICE | PROJECT | RETURN | etc.
  documentId   String
  action       String // CREATE | UPDATE | DELETE | STATUS_CHANGE
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  summary      String?
  changes      Json?
  createdAt    DateTime @default(now())

  @@index([documentType, documentId])
}

// Tracks each Business Central sync run for auditing and incremental sync
model BcSyncLog {
  id       String   @id @default(uuid())
  entity   String // "vendor" | "customer" | "item"
  status   String // "success" | "error"
  synced   Int      @default(0) // records upserted
  error    String?
  syncedAt DateTime @default(now())
}

// ─── Inventory ────────────────────────────────────────────────────────────────

enum InventoryMovementType {
  RECEIPT // shipment received — quantity increases
  BOM_ALLOCATION // item consumed by project BOM on receipt — quantity decreases
  ADJUSTMENT // manual correction
  RETURN_TO_INVENTORY // PO return to shelf — quantity increases
  RETURN_TO_VENDOR // PO return to vendor — quantity decreases
}

/// Append-only ledger. on-hand = SUM(quantityDelta) per item.
model InventoryMovement {
  id            String                @id @default(uuid())
  itemId        String
  item          Item                  @relation(fields: [itemId], references: [id])
  type          InventoryMovementType
  quantityDelta Int // positive = stock in, negative = stock out

  // Optional source references
  shipmentId    String?
  shipment      Shipment?    @relation(fields: [shipmentId], references: [id])
  invoiceId     String?
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  invoiceLineId String?
  invoiceLine   InvoiceLine? @relation(fields: [invoiceLineId], references: [id])
  bomLineId     String?
  bomLine       BOMLine?     @relation(fields: [bomLineId], references: [id])

  notes     String?
  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([type])
}
